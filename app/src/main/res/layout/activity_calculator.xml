<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121226">

    <!-- Fondo animado de partículas -->
    <com.noveasmibeta.DataPortalView
        android:id="@+id/dataPortalView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Contenido principal -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

    <!-- ========== CARD BCV TASAS ========== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bcvCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        android:alpha="0.95"
        app:cardBackgroundColor="#F2EDE4">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Título y botón refresh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tasas BCV"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#2C2416"
                    android:letterSpacing="0.03" />

                <TextView
                    android:id="@+id/bcvCacheIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📦"
                    android:textSize="10sp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone" />

                <ProgressBar
                    android:id="@+id/bcvLoader"
                    style="?android:attr/progressBarStyleSmall"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"
                    android:indeterminateTint="#C9A961" />

                <Button
                    android:id="@+id/bcvRefreshButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="↻"
                    android:textSize="18sp"
                    android:textColor="#C9A961"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />
            </LinearLayout>

            <!-- Tasas en layout horizontal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <!-- Dólar -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USD"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif"
                        android:textColor="#6B5D45"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/bcvDolarPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#2C2416" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bs."
                        android:textSize="10sp"
                        android:textColor="#8B7E6A"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Separador vertical -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="60dp"
                    android:background="#D5CAA3" />

                <!-- Euro -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EUR"
                        android:textSize="11sp"
                        android:fontFamily="sans-serif"
                        android:textColor="#6B5D45"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/bcvEuroPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="---"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="#2C2416" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bs."
                        android:textSize="10sp"
                        android:textColor="#8B7E6A"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0D5C0"
                android:layout_marginVertical="8dp" />

            <!-- Metadata compacta -->
            <TextView
                android:id="@+id/bcvFechaValor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fecha valor: ---"
                android:textSize="10sp"
                android:fontFamily="sans-serif"
                android:textColor="#6B5D45"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/bcvLastUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Última consulta: ---"
                android:textSize="10sp"
                android:fontFamily="sans-serif"
                android:textColor="#6B5D45"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/bcvVigencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#C9A961"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Título elegante -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calculadora Multimoneda"
        android:textSize="28sp"
        android:textStyle="normal"
        android:fontFamily="sans-serif-light"
        android:textColor="#D4AF37"
        android:letterSpacing="0.05"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Conversión en tiempo real"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:textColor="#E8E8E8"
        android:alpha="0.7"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <!-- ========== INPUT SUPERIOR: TENGO ========== -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:alpha="0.95"
        app:cardBackgroundColor="#D5CAA3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="TENGO"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#6B5D45"
                    android:letterSpacing="0.15" />

                <Button
                    android:id="@+id/copyTopButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📋"
                    android:textSize="14sp"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/inputTop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:textSize="36sp"
                    android:fontFamily="sans-serif-light"
                    android:textColor="#2C2416"
                    android:textColorHint="#A89B7E"
                    android:background="@android:color/transparent"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="16dp" />

                <Spinner
                    android:id="@+id/spinnerTop"
                    android:layout_width="90dp"
                    android:layout_height="52dp"
                    android:background="#BFB08A"
                    android:popupBackground="#F2EDE4"
                    android:padding="12dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Botón de intercambio -->
    <Button
        android:id="@+id/swapButton"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:text="⇅"
        android:textSize="28sp"
        android:textColor="#C9A961"
        android:background="@android:color/transparent"
        android:layout_gravity="center"
        android:layout_marginVertical="16dp"
        android:padding="0dp" />

    <!-- ========== INPUT INFERIOR: QUIERO ========== -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:alpha="0.95"
        app:cardBackgroundColor="#D5CAA3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="QUIERO"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#6B5D45"
                    android:letterSpacing="0.15" />

                <Button
                    android:id="@+id/copyBottomButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📋"
                    android:textSize="14sp"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/inputBottom"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:textSize="36sp"
                    android:fontFamily="sans-serif-light"
                    android:textColor="#2C2416"
                    android:textColorHint="#A89B7E"
                    android:background="@android:color/transparent"
                    android:paddingVertical="8dp"
                    android:layout_marginEnd="16dp" />

                <Spinner
                    android:id="@+id/spinnerBottom"
                    android:layout_width="90dp"
                    android:layout_height="52dp"
                    android:background="#BFB08A"
                    android:popupBackground="#F2EDE4"
                    android:padding="12dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Botón Volver con degradado -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="← VOLVER"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_back_gradient"
        android:paddingVertical="18dp"
        android:elevation="6dp" />

    <!-- Créditos -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Desarrollado por BRUFHALO"
        android:textSize="12sp"
        android:textColor="#606060"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>
