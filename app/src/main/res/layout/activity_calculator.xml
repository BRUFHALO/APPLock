<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Fondo animado de partículas -->
    <com.noveasmibeta.DataPortalView
        android:id="@+id/dataPortalView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Contenido principal -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="32dp"
            android:paddingBottom="16dp">

    <!-- ========== TÍTULO PRINCIPAL ========== -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Calculadora Multimoneda"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:textColor="@color/gold_main"
        android:letterSpacing="0.03"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Conversión de Divisas Globales"
        android:textSize="13sp"
        android:fontFamily="sans-serif"
        android:textColor="@color/gold_muted"
        android:gravity="center"
        android:layout_marginBottom="28dp" />

    <!-- ========== INPUT SUPERIOR ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_dark_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="0dp">

        <EditText
            android:id="@+id/inputTop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="0.00"
            android:inputType="numberDecimal"
            android:textSize="24sp"
            android:fontFamily="sans-serif-light"
            android:textColor="#FFFFFF"
            android:textColorHint="#55FFFFFF"
            android:background="@android:color/transparent"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp"
            android:maxLines="1"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <Button
                android:id="@+id/copyTopButton"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:text="📋"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerTop"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:background="@drawable/currency_button_outline"
                android:popupBackground="#31312f"
                android:padding="0dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ========== SWAP BUTTON ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginVertical="12dp">

        <Button
            android:id="@+id/swapButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="⇅"
            android:textSize="24sp"
            android:textColor="@color/gold_main"
            android:background="@drawable/swap_circle_bg"
            android:padding="0dp" />

    </LinearLayout>

    <!-- ========== INPUT INFERIOR ========== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_dark_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="28dp">

        <EditText
            android:id="@+id/inputBottom"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="0.00"
            android:inputType="numberDecimal"
            android:textSize="24sp"
            android:fontFamily="sans-serif-light"
            android:textColor="#FFFFFF"
            android:textColorHint="#55FFFFFF"
            android:background="@android:color/transparent"
            android:paddingVertical="8dp"
            android:layout_marginEnd="8dp"
            android:maxLines="1"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <Button
                android:id="@+id/copyBottomButton"
                android:layout_width="32dp"
                android:layout_height="28dp"
                android:text="📋"
                android:textSize="13sp"
                android:background="@android:color/transparent"
                android:padding="0dp"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerBottom"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:background="@drawable/currency_button_outline"
                android:popupBackground="#31312f"
                android:padding="0dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- ========== CARD BCV TASAS ========== -->
    <LinearLayout
        android:id="@+id/bcvCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_dark_bg"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginBottom="24dp">

        <!-- Título y botón refresh -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tasas BCV"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/gold_main"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/bcvCacheIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦"
                android:textSize="10sp"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <ProgressBar
                android:id="@+id/bcvLoader"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="8dp"
                android:visibility="gone"
                android:indeterminateTint="#D4AF37" />

            <Button
                android:id="@+id/bcvRefreshButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:text="↻"
                android:textSize="18sp"
                android:textColor="#D4AF37"
                android:background="@android:color/transparent"
                android:padding="0dp" />
        </LinearLayout>

        <!-- Tasas en layout horizontal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <!-- Dólar -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USD"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/bcvDolarPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bs."
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Separador vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="60dp"
                android:background="#444444" />

            <!-- Euro -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EUR"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    android:textColor="#AAAAAA"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/bcvEuroPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bs."
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginVertical="8dp" />

        <!-- Metadata compacta -->
        <TextView
            android:id="@+id/bcvFechaValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha valor: ---"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/bcvLastUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Última consulta: ---"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/bcvVigencia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#D4AF37"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ========== CARD BINANCE TASA ========== -->
    <LinearLayout
        android:id="@+id/binanceCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_dark_bg"
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tasa Binance"
                android:textSize="15sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/gold_main"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/binanceCacheIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦"
                android:textSize="10sp"
                android:layout_marginEnd="8dp"
                android:visibility="gone" />

            <Button
                android:id="@+id/binanceRefreshButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="🔄"
                android:textSize="14sp"
                android:background="@android:color/transparent" />

            <ProgressBar
                android:id="@+id/binanceLoader"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminateTint="@color/gold_main"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Precio USDT -->
        <TextView
            android:id="@+id/binancePrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---"
            android:textSize="24sp"
            android:fontFamily="sans-serif-light"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <!-- Última consulta -->
        <TextView
            android:id="@+id/binanceLastUpdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Última consulta: ---"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="2dp" />

        <!-- Valor aproximado -->
        <TextView
            android:id="@+id/binanceValorAprox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Valor aproximado"
            android:textSize="10sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/gold_main" />

    </LinearLayout>

    <!-- ========== BOTONES DE ACCIÓN ========== -->

    <!-- Botón Compartir por WhatsApp -->
    <Button
        android:id="@+id/shareWhatsappButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📤 COMPARTIR POR WHATSAPP"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_whatsapp"
        android:paddingVertical="14dp"
        android:layout_marginBottom="8dp"
        android:elevation="4dp" />

    <!-- Botón Cambiar QR -->
    <Button
        android:id="@+id/changeQrButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔄 CAMBIAR QR DEL BANCO"
        android:textSize="12sp"
        android:textColor="@color/gold_muted"
        android:background="@android:color/transparent"
        android:paddingVertical="6dp"
        android:visibility="gone" />

    <!-- Botón Volver -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="←  VOLVER"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.08"
        android:textColor="#FFFFFF"
        android:background="@drawable/card_dark_bg"
        android:paddingVertical="16dp"
        android:layout_marginTop="12dp" />

    <!-- Créditos -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Desarrollado por BRUFHALO"
        android:textSize="11sp"
        android:textColor="#44D4AF37"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>
